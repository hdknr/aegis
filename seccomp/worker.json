      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Block filesystem mount operations",
      "names": ["mount", "umount2", "pivot_root", "sysfs"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block kernel module operations",
      "names": ["init_module", "finit_module", "delete_module"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block process debugging/tracing",
      "names": ["ptrace", "process_vm_readv", "process_vm_writev", "kcmp"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block system administration",
      "names": ["reboot", "swapon", "swapoff", "sethostname", "setdomainname", "acct"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block kernel keyring access",
      "names": ["add_key", "keyctl", "request_key"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block raw I/O and hardware access",
      "names": ["ioperm", "iopl", "pciconfig_iobase", "pciconfig_read", "pciconfig_write"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block clock manipulation",
      "names": ["clock_adjtime", "clock_settime", "settimeofday", "adjtimex"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block namespace and cgroup manipulation",
      "names": ["setns", "move_mount", "open_tree", "mount_setattr", "fsopen", "fsmount", "fsconfig", "fspick"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    },
    {
      "comment": "Block BPF (eBPF) programs",
      "names": ["bpf", "perf_event_open"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    }
  ]
}
